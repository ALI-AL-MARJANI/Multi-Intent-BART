# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ── Required ─────────────────────────────────────────────────────────────────

# Disable TensorFlow detection inside HuggingFace Transformers.
# Required when TF is installed but broken/unused on your system.
USE_TF=0

# Disable HuggingFace tokenizer parallelism warnings.
TOKENIZERS_PARALLELISM=false

# ── Optional ──────────────────────────────────────────────────────────────────

# HuggingFace cache directory (default: ~/.cache/huggingface)
# HF_HOME=/path/to/hf_cache

# Override torch device for training (default: cuda if available, else cpu)
# GEMIS_DEVICE=cuda

# Weights & Biases (optional — trainer logs to W&B if this is set)
# WANDB_PROJECT=gemis
# WANDB_API_KEY=your_key_here
